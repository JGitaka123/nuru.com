# --- Core ---
NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
# Comma-separated list of allowed origins for CORS. Use "*" for any (dev only).
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Must have postgis and pgvector extensions
DATABASE_URL=postgresql://nuru:nuru@localhost:5432/nuru?schema=public

# --- Cache / Queue ---
REDIS_URL=redis://localhost:6379

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: pin model versions for reproducibility
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MODEL_OPUS=claude-opus-4-7

# --- Self-hosted inference (single GPU, see infra/inference) ---
EMBEDDING_URL=http://localhost:8001
RERANKER_URL=http://localhost:8002
WHISPER_URL=http://localhost:8003

# --- Cloudflare R2 (photos) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nuru-photos
R2_PUBLIC_URL=https://photos.nuru.com

# --- M-Pesa Daraja (start with sandbox) ---
MPESA_ENV=sandbox  # or "production"
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379  # default sandbox shortcode
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-ngrok-url/v1/webhooks/mpesa
# B2C (escrow release) — apply for these separately in production
MPESA_B2C_INITIATOR=testapi
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_SHORTCODE=600000

# --- Africa's Talking SMS ---
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=NURU

# --- WhatsApp Business (Meta) ---
# Vendor setup: docs/runbooks/vendor-setup.md §5. Until ACCESS_TOKEN is set,
# WhatsApp send calls no-op gracefully — the rest of the app still works.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=          # any random string; matches Meta webhook config
WHATSAPP_APP_SECRET=             # for X-Hub-Signature-256 verification

# --- Web Push (PWA notifications) ---
# Generate with: pnpm vapid:generate
# Set NEXT_PUBLIC_VAPID_PUBLIC_KEY in web/.env to the same public key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@nuru.com

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=Nuru <noreply@nuru.com>
EMAIL_REPLY_TO=hello@nuru.com

# --- Auth / Sessions ---
JWT_SECRET=change-me-min-32-chars
SESSION_TTL_DAYS=30

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
