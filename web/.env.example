# API endpoint. Browser hits /api/* which Next rewrites to this.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public CDN base for listing photos (R2).
NEXT_PUBLIC_PHOTO_URL=https://photos.nuru.com

# Web Push public key — must match the API-side VAPID_PUBLIC_KEY.
# Generate the keypair on the API side with: pnpm vapid:generate
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
