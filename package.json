{
  "name": "nuru",
  "version": "0.1.0",
  "private": true,
  "packageManager": "[email protected]",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers/index.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "ai:eval": "tsx scripts/run-evals.ts",
    "ai:mine-evals": "tsx scripts/mine-evals.ts",
    "vapid:generate": "tsx scripts/generate-vapid.ts",
    "mpesa:simulate": "tsx scripts/simulate-stk.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@prisma/client": "^5.20.0",
    "africastalking": "^0.7.0",
    "axios": "^1.7.0",
    "bullmq": "^5.10.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prisma": "^5.20.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
